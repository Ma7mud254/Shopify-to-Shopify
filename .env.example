# ExportBase Environment Variables

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/exportbase?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-change-in-production"
SHOPIFY_APP_URL="http://localhost:3000"

# Shopify App Credentials
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""
SHOPIFY_SCOPES="read_products,write_products,read_product_listings,read_inventory,write_inventory,read_content,write_content,read_themes,read_publications,write_publications"

# Encryption key for Shopify access tokens
TOKEN_ENCRYPTION_KEY="your-32-byte-hex-key-change-in-production"

# Redis (for BullMQ)
REDIS_URL="redis://localhost:6379"

# S3 / R2 Storage (for reports/exports)
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_REGION="auto"

# Sentry
SENTRY_DSN=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
