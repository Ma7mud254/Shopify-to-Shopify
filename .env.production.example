# ExportBase production environment variables

# App URL
NEXTAUTH_URL="https://your-domain.com"
SHOPIFY_APP_URL="https://your-domain.com"

# Security
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
TOKEN_ENCRYPTION_KEY="replace-with-32-characters-exactly"

# Database and queue
DATABASE_URL="postgresql://user:password@host:5432/exportbase?sslmode=require"
REDIS_URL="redis://default:password@host:6379"

# Shopify app credentials
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""
SHOPIFY_SCOPES="read_products,write_products,read_product_listings,read_inventory,write_inventory,read_content,write_content,read_themes,read_publications,write_publications"

# Authentication
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional storage for reports
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_REGION="auto"

# Optional monitoring / billing
SENTRY_DSN=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
